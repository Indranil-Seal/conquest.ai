# conquest.ai Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override the default model (default: claude-sonnet-4-6)
# CONQUEST_MODEL=claude-sonnet-4-6

# Optional: Override ChromaDB storage path (default: ./data/chroma_db)
# CHROMA_DB_PATH=./data/chroma_db

# Optional: Override DREAM library path (default: ./DREAM)
# DREAM_PATH=./DREAM
